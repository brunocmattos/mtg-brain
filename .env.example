# Postgres (o docker-compose lê estas variáveis)
POSTGRES_USER=mtg
POSTGRES_PASSWORD=mtg
POSTGRES_DB=mtg
POSTGRES_PORT=5432

# String de conexão usada pelo Python (host = localhost porque o container expõe a porta)
DATABASE_URL=postgresql://mtg:mtg@localhost:5432/mtg

# Onde cachear os bulks baixados
DATA_DIR=data

# Identifique-se pro Scryfall (boa prática). Pode pôr seu e-mail/projeto.
USER_AGENT=mtg-brain/0.1 (bruno; personal project)
SCRYFALL_REQUEST_DELAY=0.1

# Commander Spellbook (combos)
CSB_API=https://backend.commanderspellbook.com

# Comprehensive Rules: pegue o link do .txt atual em https://magic.wizards.com/en/rules
# (muda a cada coleção) e cole aqui. Ex.: https://media.wizards.com/.../MagicCompRules.txt
CR_TXT_URL=

# Perguntas em linguagem natural são feitas via Claude Code + servidor MCP de Postgres
# (sem LLM local). Conecte uma vez:
#   claude mcp add mtg-brain -s user -- npx -y @modelcontextprotocol/server-postgres "postgresql://mtg:mtg@localhost:5432/mtg"
